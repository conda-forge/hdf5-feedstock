From 2f693d6e0b20beb359ff5a5563e5fb5fd0ebe805 Mon Sep 17 00:00:00 2001
From: Julien Schueller <schueller@phimeca.com>
Date: Thu, 1 Jan 2026 14:24:49 +0100
Subject: [PATCH 2/4] Add wine wrapper

---
 .github/workflows/cross-compile.yml | 1 +
 config/toolchain/mingw64.cmake      | 2 --
 config/toolchain/wine64.sh          | 7 +++++++
 3 files changed, 8 insertions(+), 2 deletions(-)
 create mode 100755 config/toolchain/wine64.sh

diff --git a/.github/workflows/cross-compile.yml b/.github/workflows/cross-compile.yml
index 5d3f40d5575..eb26219e959 100644
--- a/.github/workflows/cross-compile.yml
+++ b/.github/workflows/cross-compile.yml
@@ -58,6 +58,7 @@ jobs:
              -G Ninja \
              --log-level=VERBOSE \
              -DCMAKE_TOOLCHAIN_FILE:STRING=config/toolchain/mingw64.cmake \
+             -DCMAKE_CROSSCOMPILING_EMULATOR:PATH=$GITHUB_WORKSPACE/config/toolchain/wine64.sh \
              -DCMAKE_BUILD_TYPE=${{ inputs.build_mode }} \
              -DHDF5_ENABLE_DOXY_WARNINGS:BOOL=ON \
              -DHDF5_BUILD_DOC:BOOL=ON \
diff --git a/config/toolchain/mingw64.cmake b/config/toolchain/mingw64.cmake
index 86c235908e0..5d159e75fcf 100644
--- a/config/toolchain/mingw64.cmake
+++ b/config/toolchain/mingw64.cmake
@@ -25,8 +25,6 @@ set (CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
 set (CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
 set (CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
 set (CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
-set (CMAKE_CROSSCOMPILING_EMULATOR wine64)
-set (CROSSCOMPILING_PATH "WINEPATH=/usr/${TOOLCHAIN_PREFIX}/sys-root/mingw/bin/")
 
 set (CMAKE_WINDOWS_EXPORT_ALL_SYMBOLS On CACHE BOOL "Export windows symbols")
 
diff --git a/config/toolchain/wine64.sh b/config/toolchain/wine64.sh
new file mode 100755
index 00000000000..7580e032177
--- /dev/null
+++ b/config/toolchain/wine64.sh
@@ -0,0 +1,7 @@
+#!/bin/sh
+
+set -e
+
+# assume gfortran-mingw-w64-x86-64-win32 is installed
+export WINEPATH=`dirname /usr/lib/gcc/x86_64-w64-mingw32/*-win32/libgfortran.dll.a`
+/usr/lib/wine/wine64 "$@"

